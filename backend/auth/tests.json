{
  "tests": [
    {
      "name": "Проверка сессии без токена",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401
    },
    {
      "name": "Вход с неверными данными",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "phone": "+70000000000", "password": "wrongpass"},
      "expectedStatus": 401
    }
  ]
}
